{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Desktop",
  "version": "0.1.0",
  "identifier": "com.hermes.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hermes Desktop",
        "width": 1920,
        "height": 1080,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' http://127.0.0.1:8642 https://api.github.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "run-shell",
          "cmd": "sh",
          "args": ["-c", true]
        },
        {
          "name": "run-shell",
          "cmd": "bash",
          "args": ["-c", true]
        },
        {
          "name": "run-shell",
          "cmd": "cmd",
          "args": ["/C", true]
        },
        {
          "name": "run-shell",
          "cmd": "powershell",
          "args": ["-Command", true]
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": ["-c", true]
        },
        {
          "name": "python",
          "cmd": "python",
          "args": ["-c", true]
        },
        {
          "name": "node",
          "cmd": "node",
          "args": ["-e", true]
        }
      ]
    },
    "fs": {
      "scope": [
        "$APPDATA/**",
        "$HOME/**",
        "$DESKTOP/**",
        "$DOCUMENT/**",
        "$DOWNLOAD/**"
      ],
      "readDir": true,
      "readFile": true,
      "writeFile": true,
      "createDir": true,
      "removeFile": false,
      "renameFile": false
    }
  }
}
